{
  "name": "@wbsender/sdk",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript SDK for the WbSender WhatsApp Marketing API",
  "keywords": [
    "whatsapp",
    "wbsender",
    "sdk",
    "marketing",
    "api"
  ],
  "license": "MIT",
  "author": "WbSender",
  "repository": {
    "type": "git",
    "url": "https://github.com/coder-aminul/wbsender-sdk"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
